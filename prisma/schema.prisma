generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  SAVED
  READY_TO_APPLY
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum JobType {
  REMOTE
  HYBRID
  ONSITE
}

enum SkipRuleType {
  TITLE
  COMPANY
  URL
}

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  passwordHash    String
  createdAt       DateTime          @default(now())
  resumes         Resume[]
  jobApplications JobApplication[]
  oneClickJobs    OneClickJob[]
}

model OneClickJob {
  id          Int       @id @default(autoincrement())
  userId      Int
  source      String    @db.VarChar(50)
  title       String
  company     String
  externalUrl String    @db.VarChar(2048)
  fullText    String
  appliedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, externalUrl])
}

model Resume {
  id         Int       @id @default(autoincrement())
  userId     Int
  name       String
  rawText    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  tailoredResumes TailoredResume[]
  coverLetters    CoverLetter[]
}

model JobApplication {
  id                 Int               @id @default(autoincrement())
  userId             Int
  source             String            @default("jobright") @db.VarChar(50)
  jobrightJobId      String?           @db.VarChar(255)
  title              String
  company            String
  location           String?
  jobType            JobType           @default(REMOTE)
  jobrightMatchScore Float?
  jobrightBoard      String?           @db.VarChar(50)
  jobrightUrl        String?           @db.VarChar(500)
  externalUrl        String            @db.VarChar(2048)
  status             ApplicationStatus @default(SAVED)
  invitedToInterview Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  appliedAt          DateTime?

  user          User          @relation(fields: [userId], references: [id])
  jobDescription JobDescription?
  tailoredResumes TailoredResume[]
  coverLetters    CoverLetter[]

  @@unique([userId, externalUrl])
  @@unique([userId, title, company])
}

model JobDescription {
  id               Int            @id @default(autoincrement())
  jobApplicationId Int            @unique
  fullText         String
  source           String         @default("company_site")
  createdAt        DateTime       @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])
}

model TailoredResume {
  id               Int       @id @default(autoincrement())
  jobApplicationId Int
  baseResumeId     Int
  llmModel         String
  promptVersion    String
  outputText       String
  createdAt        DateTime  @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])
  baseResume     Resume        @relation(fields: [baseResumeId], references: [id])
}

model CoverLetter {
  id               Int       @id @default(autoincrement())
  jobApplicationId Int
  baseResumeId     Int?
  llmModel         String
  promptVersion    String
  outputText       String
  createdAt        DateTime  @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])
  baseResume     Resume?       @relation(fields: [baseResumeId], references: [id])
}

// ── Admin configuration ─────────────────────────────────────────────────────

model AppConfig {
  key       String   @id @db.VarChar(255)
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model SkipRule {
  id        Int          @id @default(autoincrement())
  type      SkipRuleType
  pattern   String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
}

model UserProfile {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  baseResumeText String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ScanLog {
  id        Int      @id @default(autoincrement())
  board     String   @db.VarChar(50)
  jobsFound Int      @default(0)
  jobsSaved Int      @default(0)
  errors    String?
  durationMs Int?
  createdAt DateTime @default(now())
}

model GenerationLog {
  id             Int      @id @default(autoincrement())
  jobApplicationId Int
  model          String   @db.VarChar(100)
  promptVersion  String   @db.VarChar(100)
  success        Boolean  @default(true)
  error          String?
  tokensUsed     Int?
  durationMs     Int?
  createdAt      DateTime @default(now())
}
