{
  "manifest_version": 3,
  "name": "LinkedIn Job Scanner",
  "version": "1.1.0",
  "description": "Scans LinkedIn job search results, analyzes suitability with AI, and saves approved jobs to Google Sheets.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*", "https://*.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://www.linkedin.com/jobs/search/*", "https://www.linkedin.com/jobs/collections/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
