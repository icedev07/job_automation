generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkipRuleType {
  TITLE
  COMPANY
  URL
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Core ────────────────────────────────────────────────────────────────────

model ScrapedJob {
  id          Int       @id @default(autoincrement())
  platform    String    @db.VarChar(50)
  title       String
  company     String
  location    String?
  url         String    @db.VarChar(2048)
  description String?
  salary      String?
  techStack   String?
  status      JobStatus @default(PENDING)
  aiScore     Int?
  aiReason    String?
  sheetSynced Boolean   @default(false)
  createdAt   DateTime  @default(now())

  analysisLogs AnalysisLog[]

  @@unique([platform, url])
  @@unique([platform, title, company])
}

// ── Admin configuration ─────────────────────────────────────────────────────

model AppConfig {
  key       String   @id @db.VarChar(255)
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model SkipRule {
  id        Int          @id @default(autoincrement())
  type      SkipRuleType
  pattern   String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
}

// ── Logging ─────────────────────────────────────────────────────────────────

model ScanLog {
  id         Int      @id @default(autoincrement())
  board      String   @db.VarChar(50)
  jobsFound  Int      @default(0)
  jobsSaved  Int      @default(0)
  errors     String?
  durationMs Int?
  createdAt  DateTime @default(now())
}

model AnalysisLog {
  id           Int      @id @default(autoincrement())
  scrapedJobId Int
  model        String   @db.VarChar(100)
  approved     Boolean
  score        Int?
  reason       String?
  tokensUsed   Int?
  durationMs   Int?
  createdAt    DateTime @default(now())

  scrapedJob ScrapedJob @relation(fields: [scrapedJobId], references: [id], onDelete: Cascade)
}

model ExtensionLog {
  id        Int      @id @default(autoincrement())
  level     String   @default("info") @db.VarChar(20)
  message   String
  sessionId String?  @db.VarChar(100)
  createdAt DateTime @default(now())
}
