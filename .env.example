# ==============================================================================
# Job Application Bot — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# ==============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# For local development:
DATABASE_URL="postgresql://jobbot:yourpassword@localhost:5432/jobbot"
# For Docker Compose (auto-configured, but you must set these):
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=jobbot
POSTGRES_PORT=5432

# ── Web Server ────────────────────────────────────────────────────────────────
WEB_PORT=3000
NODE_ENV=production

# ── User Profile ──────────────────────────────────────────────────────────────
JOBBOT_USER_ID=1

# ── Jobright Scanner ─────────────────────────────────────────────────────────
JOBRIGHT_CONTEXT_DIR=~/.jobbot/jobright
MAX_JOBS=10
MATCH_SCORE_THRESHOLD=70

# ── ZipRecruiter (optional — leave empty to disable) ─────────────────────────
ZIPRECRUITER_SEARCH_URL=
# ZIPRECRUITER_MAX_JOBS_PER_RUN=10
# ZIPRECRUITER_CONTEXT_DIR=~/.jobbot/ziprecruiter
# ZIPRECRUITER_COOKIES_FILE=~/.jobbot/ziprecruiter-cookies.json

# ── Glassdoor (optional) ─────────────────────────────────────────────────────
GLASSDOOR_SEARCH_URL=
# GLASSDOOR_MAX_JOBS_PER_RUN=5
# GLASSDOOR_CONTEXT_DIR=~/.jobbot/glassdoor

# ── Dice (optional) ──────────────────────────────────────────────────────────
DICE_SEARCH_URL=
# DICE_MAX_JOBS_PER_RUN=10
# DICE_CONTEXT_DIR=~/.jobbot/dice

# ── Simplify (optional) ──────────────────────────────────────────────────────
SIMPLIFY_SEARCH_URL=
# SIMPLIFY_MAX_JOBS_PER_RUN=5
# SIMPLIFY_CONTEXT_DIR=~/.jobbot/simplify

# ── Scanner Cron Schedules (Docker only) ──────────────────────────────────────
# Format: standard cron (minute hour day month weekday)
CRON_JOBRIGHT=0 */2 * * *
CRON_ZIPRECRUITER=30 */4 * * *
CRON_GLASSDOOR=0 */4 * * *
CRON_DICE=15 */4 * * *
CRON_SIMPLIFY=45 */4 * * *

# ── Document Generation (backfill worker) ─────────────────────────────────────
BACKFILL_POLL_INTERVAL_SEC=120
RESUMES_OUTPUT_DIR=Resumes
MOHAN_RESUMES_OUTPUT_DIR=Resumes_Mohan
# RESUME_SAMPLE_PATH=Resumes/Templates/Jiayong Lin_Sample.docx
# RESUME_TEMPLATE_PATH=Resumes/Templates/Jiayong Lin.docx
# COVER_LETTER_TEMPLATE_PATH=Resumes/Templates/Cover Letter.docx
# RESUME_OUTPUT_FILENAME=Jiayong Lin.docx

# ── ChatGPT UI Automation ────────────────────────────────────────────────────
# CHATGPT_CONTEXT_DIR=~/.jobbot/chatgpt
# CHATGPT_COOKIES_FILE=~/.jobbot/chatgpt-cookies.json
# CHATGPT_CHROME_PATH=/usr/bin/google-chrome

# ── ChatGPT SeleniumBase Backfill ─────────────────────────────────────────────
# CHATGPT_BACKFILL_POLL_SECONDS=300
# CHATGPT_BACKFILL_RUN_ONCE=0
# CHATGPT_BACKFILL_JOBS_PER_CHAT=20
# CHATGPT_BACKFILL_UNATTENDED=1
# CHATGPT_BACKFILL_MAX_CONSECUTIVE_FAILURES=1

# ── PDF Converter (watch mode) ───────────────────────────────────────────────
DOCX_PDF_WATCH_POLL_SECONDS=300
DOCX_PDF_SUBDIR_WITHIN_DAYS=7
# DOCX_PDF_WATCH_ROOTS=Resumes_Mohan;Resumes

# ── Browser Profiles Base Dir ────────────────────────────────────────────────
# JOBOT_DIR=~/.jobbot
