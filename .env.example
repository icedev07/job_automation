# Required: PostgreSQL connection string (Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Optional: overrides admin login when set (same variable on Vercel if DB is empty or you need a known password)
# ADMIN_PASSWORD=admin

# Optional: Set to "production" for deployment
NODE_ENV=development

# All other settings (OpenAI key, Google Sheets, target market, etc.)
# are configured from the Admin Panel at /admin/settings
