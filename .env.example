# ── Database (required) ────────────────────────────────────────
# Supabase PostgreSQL connection string (free tier)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ── Node environment ──────────────────────────────────────────
NODE_ENV=development

# ── All other settings are configured via the Admin Panel ─────
# Visit /admin after starting the app to configure:
#   - OpenAI API Key
#   - OpenAI Model (default: gpt-4o-mini)
#   - Google Sheets credentials & Sheet ID
#   - Admin password (default: admin)
#   - Resume & cover letter prompt templates
#   - Scanner settings (search URLs, max jobs)
#   - Skip rules (blocked companies/titles/URLs)
#   - User profiles (name, email, base resume text)
