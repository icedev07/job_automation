# Required: Supabase session pooler connection string (port 5432, NOT 6543)
# Get it from Supabase > Connect > Direct > Session pooler > URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-[n]-[region].pooler.supabase.com:5432/postgres

# Optional: overrides admin login when set (useful if DB is empty or you need a known password)
# ADMIN_PASSWORD=admin

# Optional: set to "production" for deployment
NODE_ENV=development

# All other settings (OpenAI key, Google Sheets, target market, etc.)
# are configured from the Admin Panel at /admin/settings
