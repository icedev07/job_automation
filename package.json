{
  "name": "job-application-bot",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",

    "jobright:login": "tsx scripts/loginToJobright.ts",
    "jobright:scan": "tsx scripts/jobrightScan.ts",

    "ziprecruiter:init": "tsx scripts/ziprecruiterInit.ts",
    "ziprecruiter:scan": "tsx scripts/ziprecruiterScan.ts",

    "glassdoor:init": "tsx scripts/glassdoorInit.ts",
    "glassdoor:scan": "tsx scripts/glassdoorScan.ts",

    "dice:init": "tsx scripts/diceInit.ts",
    "dice:scan": "tsx scripts/diceScan.ts",

    "simplify:init": "tsx scripts/simplifyInit.ts",
    "simplify:scan": "node --max-old-space-size=4096 node_modules/tsx/dist/cli.mjs scripts/simplifyScan.ts",

    "resume:setup": "tsx scripts/addBaseResume.ts",
    "profiles:ensure": "tsx scripts/ensureProfileUsers.ts",
    "cache:clean": "tsx scripts/cleanJobbotCache.ts",
    "jobdesc:cleanup-bad": "tsx scripts/cleanupBadJobDescriptions.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "googleapis": "^171.4.0",
    "next": "14.2.11",
    "openai": "^6.35.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.11",
    "playwright": "1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "prisma": "5.22.0",
    "ts-node": "10.9.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
