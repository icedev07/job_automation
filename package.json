{
  "name": "job-application-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo --hostname 0.0.0.0",
    "dev:3001": "next dev --turbo -p 3001 -H 0.0.0.0",
    "dev:test-server": "node scripts/minimal-server.js",
    "tunnel": "npx --yes localtunnel --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "jobright:login": "tsx scripts/loginToJobright.ts",
    "jobright": "tsx scripts/jobrightScan.ts",
    "resume:setup": "tsx scripts/addBaseResume.ts",
    "resume:test-mohan-headline": "tsx scripts/testMohanResumeHeadline.ts",
    "chatgpt:seleniumbase": "py -3.12 scripts/chatgpt_seleniumbase.py",
    "chatgpt": "py -3.12 scripts/chatgpt_seleniumbase_backfill.py",
    "ziprecruiter:init": "tsx scripts/ziprecruiterInit.ts",
    "ziprecruiter:scan": "tsx scripts/ziprecruiterScan.ts",
    "ziprecruiter:seleniumbase": "py -3.12 scripts/ziprecruiter_seleniumbase.py",
    "ziprecruiter": "set ZIPRECRUITER_RUN_SCAN_AFTER_EXPORT=1&& py -3.12 scripts/ziprecruiter_seleniumbase.py",
    "glassdoor:init": "tsx scripts/glassdoorInit.ts",
    "glassdoor:scan": "tsx scripts/glassdoorScan.ts",
    "dice:init": "tsx scripts/diceInit.ts",
    "dice:scan": "tsx scripts/diceScan.ts",
    "simplify:init": "tsx scripts/simplifyInit.ts",
    "simplify": "node --max-old-space-size=4096 node_modules/tsx/dist/cli.mjs scripts/simplifyScan.ts",
    "indeed:seleniumbase": "py -3.12 scripts/indeed_seleniumbase.py",
    "profiles:ensure": "tsx scripts/ensureProfileUsers.ts",
    "cache:clean": "tsx scripts/cleanJobbotCache.ts",
    "jobdesc:cleanup-bad": "tsx scripts/cleanupBadJobDescriptions.ts",
    "docs:reset-user": "tsx scripts/resetUserGeneratedDocuments.ts",
    "docx:pdf": "py -3.12 scripts/convertDocxToPdf.py",
    "convert:mohan": "py -3.12 scripts/convertDocxToPdf.py Resumes_Mohan --subdir-within-days=2",
    "convert:jiayong": "py -3.12 scripts/convertDocxToPdf.py Resumes --subdir-within-days=2",
    "convert:mohan:all": "py -3.12 scripts/convertDocxToPdf.py Resumes_Mohan",
    "convert:jiayong:all": "py -3.12 scripts/convertDocxToPdf.py Resumes",
    "convert:watch": "py -3.12 scripts/convertDocxToPdf.py --watch",
    "convert:watch:once": "py -3.12 scripts/convertDocxToPdf.py --watch --run-once"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "dotenv": "^16.4.5",
    "docx": "^9.5.2",
    "docxtemplater": "^3.68.1",
    "mammoth": "^1.11.0",
    "next": "14.2.11",
    "pizzip": "^3.2.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.11",
    "playwright": "1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "prisma": "5.22.0",
    "ts-node": "10.9.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
